{
    "manifest_version": 3,
    "name": "Chrome ChatHub",
    "version": "3.9.0",
    "description": "A centralized hub for multiple AI chat services. Expert Reviewed.",
    "permissions": [
        "storage",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess",
        "scripting"
    ],
    "optional_host_permissions": [
        "https://*/*"
    ],
    "host_permissions": [
        "https://chatgpt.com/*",
        "https://web.tabbitbrowser.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.doubao.com/*",
        "https://www.qianwen.com/*",
        "https://yiyan.baidu.com/*",
        "https://www.kimi.com/*",
        "https://chat.deepseek.com/*",
        "https://chatglm.cn/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "src/rules.json"
            }
        ]
    },
    "icons": {
        "16": "public/icon-16.png",
        "32": "public/icon-32.png",
        "48": "public/icon-48.png",
        "128": "public/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "public/icon-16.png",
            "32": "public/icon-32.png",
            "48": "public/icon-48.png",
            "128": "public/icon-128.png"
        }
    },
    "options_page": "index.html",
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*"
            ],
            "matches": [
                "https://chatgpt.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*",
                "https://www.doubao.com/*",
                "https://www.qianwen.com/*",
                "https://chatglm.cn/*"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://web.tabbitbrowser.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*",
                "https://copilot.microsoft.com/*",
                "https://www.doubao.com/*",
                "https://www.qianwen.com/*",
                "https://yiyan.baidu.com/*",
                "https://www.kimi.com/*",
                "https://chat.deepseek.com/*",
                "https://chatglm.cn/*"
            ],
            "js": [
                "src/content/index.ts"
            ],
            "run_at": "document_idle",
            "all_frames": true,
            "match_about_blank": true
        }
    ]
}